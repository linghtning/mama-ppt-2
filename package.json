{
  "name": "yiruite-report-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Offline weekly report desktop app for Yiruite Packaging",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host=0.0.0.0",
    "dev:renderer:desktop": "vite --port=3000 --host=127.0.0.1 --strictPort",
    "dev:electron": "wait-on http-get://127.0.0.1:3000 && tsc -p tsconfig.electron.json && electron .",
    "dev:desktop": "concurrently -k \"pnpm:dev:renderer:desktop\" \"pnpm:dev:electron\"",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:desktop": "pnpm run build && pnpm run build:electron",
    "dist:win": "pnpm run build:desktop && electron-builder --win --config.win.signAndEditExecutable=false",
    "dist:win:dir": "pnpm run build:desktop && electron-builder --win --dir --config.win.signAndEditExecutable=false",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron release",
    "lint": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "build": {
    "appId": "com.yiruite.report",
    "productName": "依瑞特汇报系统",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "artifactName": "yiruite-report-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "yiruite-report-portable-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.5"
  }
}
